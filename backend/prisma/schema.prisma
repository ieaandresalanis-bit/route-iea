// ── Campaign Attribution ─────────────────────────────────────

model Campaign {
  id          String @id @default(uuid())

  // Identity
  name           String   @unique              // Normalized: "Meta Solar GDL"
  zohoName       String?  @map("zoho_name")    // Original from Zoho: "PANELES SOLARES NEGOCIOS 3 SEGMENTADA"
  campaignGroup  String   @map("campaign_group") // Group: "Solar", "Arrendamiento", "Centros de Utilidad", etc.
  campaignType   String   @map("campaign_type")  // performance | branding | referral | organic | internal | database

  // Channel
  channel        String   // Meta | Google | TikTok | Referral | Outbound | Organic | WhatsApp | Wiki | Database
  sourceType     String   @map("source_type")  // paid | organic | referral | outbound | database | internal

  // Cost tracking
  monthlyCost    Float?   @map("monthly_cost")     // Monthly ad spend in MXN
  totalCost      Float?   @map("total_cost")       // Lifetime total cost
  costCurrency   String   @default("MXN") @map("cost_currency")
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")

  // Status
  isActive       Boolean  @default(true) @map("is_active")

  // Metadata
  description    String?  @db.Text
  targetZone     String?  @map("target_zone")     // BAJIO, OCCIDENTE, CENTRO, etc.
  targetProduct  String?  @map("target_product")   // solar, arrendamiento, industrial

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  attributions CampaignAttribution[]

  @@index([channel])
  @@index([campaignGroup])
  @@index([campaignType])
  @@index([sourceType])
  @@map("campaigns")
}

model CampaignAttribution {
  id          String @id @default(uuid())

  // Link to lead
  leadId      String  @map("lead_id")

  // Campaign reference
  campaignId  String? @map("campaign_id")
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  // Denormalized for fast queries
  campaignName    String?  @map("campaign_name")
  campaignGroup   String?  @map("campaign_group")
  campaignType    String?  @map("campaign_type")    // performance | branding | referral | organic | internal | database
  channel         String?                            // Meta | Google | TikTok | Referral | Outbound | Organic | WhatsApp | Wiki | Database
  sourceType      String?  @map("source_type")       // paid | organic | referral | outbound | database | internal

  // Original Zoho data (preserved for audit)
  zohoLeadSource  String?  @map("zoho_lead_source")  // Raw Lead_Source from Zoho
  zohoAdCampaign  String?  @map("zoho_ad_campaign")  // Raw Ad_Campaign from Zoho
  zohoUtmSource   String?  @map("zoho_utm_source")
  zohoUtmMedium   String?  @map("zoho_utm_medium")
  zohoUtmCampaign String?  @map("zoho_utm_campaign")

  // Inference metadata
  attributionMethod String @default("manual") @map("attribution_method") // zoho_sync | inferred_source | inferred_campaign | utm | manual
  confidence        Float  @default(1.0) // 0.0–1.0

  // Deal/revenue linkage
  dealStage       String?  @map("deal_stage")
  dealAmount      Float?   @map("deal_amount")
  dealPipeline    String?  @map("deal_pipeline")
  isWon           Boolean  @default(false) @map("is_won")
  revenueAttributed Float? @map("revenue_attributed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([leadId])
  @@index([campaignId])
  @@index([channel])
  @@index([campaignGroup])
  @@index([sourceType])
  @@index([isWon])
  @@map("campaign_attributions")
}

// ── Post-Sale Client Lifecycle ──────────────────────────────

model ClientProfile {
  id       String @id @default(uuid())

  // Link to lead (1:1 for CERRADO_GANADO leads)
  leadId   String @unique @map("lead_id")

  // Client info (denormalized for performance)
  companyName  String @map("company_name")
  contactName  String @map("contact_name")
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")
  advisorId    String? @map("advisor_id")
  zone         String?
  city         String?
  industry     String?

  // Project & system
  systemStatus       ClientSystemStatus @default(PENDING) @map("system_status")
  projectCompletedAt DateTime?          @map("project_completed_at")
  installationDate   DateTime?          @map("installation_date")
  systemSize         String?            @map("system_size") // e.g. "15kW"
  projectNotes       String?            @map("project_notes") @db.Text

  // Lifecycle
  lifecycleStage  ClientLifecycleStage @default(NEW_CLIENT) @map("lifecycle_stage")
  lastContactedAt DateTime?            @map("last_contacted_at")
  nextFollowUpAt  DateTime?            @map("next_follow_up_at")

  // Satisfaction
  satisfactionScore Int?    @map("satisfaction_score") // 1-10
  satisfactionNotes String? @map("satisfaction_notes") @db.Text
  lastSurveyAt      DateTime? @map("last_survey_at")
  npsScore          Int?      @map("nps_score") // -100 to 100

  // Revenue
  totalRevenue     Float   @default(0) @map("total_revenue")
  projectCount     Int     @default(1) @map("project_count")
  avgProjectValue  Float   @default(0) @map("avg_project_value")
  lifetimeValue    Float   @default(0) @map("lifetime_value") // LTV

  // Expansion potential
  expansionScore   Int     @default(50) @map("expansion_score") // 0-100
  expansionType    String? @map("expansion_type") // expansion | upgrade | cross_sell
  expansionNotes   String? @map("expansion_notes") @db.Text
  hasMultipleLocations Boolean @default(false) @map("has_multiple_locations")

  // Referral tracking
  referralCount    Int     @default(0) @map("referral_count")
  referralRevenue  Float   @default(0) @map("referral_revenue")
  isReferralSource Boolean @default(false) @map("is_referral_source")

  // Churn risk
  churnRisk        Int     @default(0) @map("churn_risk") // 0-100
  churnReason      String? @map("churn_reason")

  // Timestamps
  becameClientAt DateTime  @default(now()) @map("became_client_at")
  reactivatedAt  DateTime? @map("reactivated_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  referrals      Referral[]
  postSaleSteps  PostSaleStep[]

  @@index([lifecycleStage])
  @@index([systemStatus])
  @@index([advisorId])
  @@index([zone])
  @@index([expansionScore])
  @@index([churnRisk])
  @@index([totalRevenue])
  @@index([lastContactedAt])
  @@map("client_profiles")
}

model PostSaleStep {
  id       String @id @default(uuid())

  clientId String @map("client_id")
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Step definition
  stepType    String  @map("step_type") // onboarding | satisfaction_check | performance_review | upsell_check | expansion_offer | referral_request | reactivation
  channel     String  // whatsapp | sms | email | call | crm_task
  dayOffset   Int     @map("day_offset") // days after project completion
  subject     String?
  messageBody String  @map("message_body") @db.Text

  // Scheduling & execution
  scheduledAt DateTime? @map("scheduled_at")
  status      String    @default("pending") // pending | sent | delivered | opened | replied | skipped | cancelled
  sentAt      DateTime? @map("sent_at")
  openedAt    DateTime? @map("opened_at")
  repliedAt   DateTime? @map("replied_at")

  // Outcome
  outcome     String?  // positive | neutral | negative | no_response
  notes       String?  @db.Text
  ledToAction Boolean  @default(false) @map("led_to_action") // upsell, referral, etc.
  actionType  String?  @map("action_type") // upsell | referral | reactivation | none

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@index([scheduledAt])
  @@index([stepType])
  @@map("post_sale_steps")
}

model Referral {
  id       String @id @default(uuid())

  // Source client
  referrerId  String @map("referrer_id")
  referrer    ClientProfile @relation(fields: [referrerId], references: [id])

  // Referred lead
  referredLeadId String?  @map("referred_lead_id") // created lead if converted
  referredName   String   @map("referred_name")
  referredCompany String? @map("referred_company")
  referredPhone  String?  @map("referred_phone")
  referredEmail  String?  @map("referred_email")
  referredIndustry String? @map("referred_industry")

  // Status
  status    ReferralStatus @default(REQUESTED)
  assignedToId String?     @map("assigned_to_id")

  // Tracking
  requestedAt  DateTime  @default(now()) @map("requested_at")
  receivedAt   DateTime? @map("received_at")
  convertedAt  DateTime? @map("converted_at")
  revenue      Float?    // revenue from referred deal

  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([referrerId])
  @@index([status])
  @@index([referredLeadId])
  @@map("referrals")
}

model ClientAlert {
  id       String @id @default(uuid())

  clientId  String  @map("client_id")
  advisorId String? @map("advisor_id")

  // Alert definition
  type     String // no_followup | inactive_client | upsell_opportunity | referral_opportunity | churn_risk | expansion_detected | satisfaction_low
  severity String // critical | high | medium | low
  title    String
  message  String @db.Text
  recommendation String? @db.Text

  // Scoring
  priorityScore  Int    @default(50) @map("priority_score") // 0-100
  estimatedValue Float? @map("estimated_value")

  // State
  status     String   @default("open") // open | acknowledged | resolved | dismissed
  resolvedAt DateTime? @map("resolved_at")
  actionTaken String?  @map("action_taken")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([type])
  @@index([status])
  @@index([severity])
  @@index([priorityScore])
  @@map("client_alerts")
}

// ── Live Chat: Contact Timeline ───────────────────────────────

model ContactTimeline {
  id            String   @id @default(uuid())
  leadId        String   @map("lead_id")
  zohoRecordId  String?  @map("zoho_record_id")
  zohoModule    String?  @map("zoho_module") // Leads | Deals | Contacts
  eventType     String   @map("event_type") // note | sms | whatsapp | email | call | stage_change | reminder | conversion | system
  eventSource   String   @map("event_source") // manual | automation | zoho_sync | sms_masivos | system
  channel       String?  // whatsapp | sms | email | phone | in_person
  content       String?  @db.Text
  metadata      Json?    // extra context (old_stage, new_stage, sms_status, etc.)
  advisorId     String?  @map("advisor_id")
  advisorName   String?  @map("advisor_name")
  status        String   @default("completed") // completed | pending | failed
  createdAt     DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([advisorId])
  @@index([eventType])
  @@index([createdAt])
  @@index([zohoRecordId])
  @@map("contact_timeline")
