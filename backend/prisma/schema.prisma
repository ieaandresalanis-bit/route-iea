  advisorId     String   @map("advisor_id")
  advisorName   String?  @map("advisor_name")
  title         String
  description   String?  @db.Text
  dueDate       DateTime @map("due_date")
  priority      String   @default("medium") // critical | high | medium | low
  status        String   @default("pending") // pending | completed | overdue | cancelled
  completedAt   DateTime? @map("completed_at")
  zohoTaskId    String?  @map("zoho_task_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([advisorId])
  @@index([dueDate])
  @@index([status])
  @@map("reminders")
}

// ── Live Chat: SMS Log ────────────────────────────────────────

model SmsLog {
  id            String   @id @default(uuid())
  leadId        String?  @map("lead_id")
  advisorId     String   @map("advisor_id")
  advisorName   String?  @map("advisor_name")
  phone         String
  message       String   @db.Text
  direction     String   @default("outbound") // outbound | inbound
  status        String   @default("sent") // queued | sent | delivered | failed | retry
  provider      String   @default("sms_masivos")
  providerMsgId String?  @map("provider_msg_id")
  errorMessage  String?  @map("error_message")
  retryCount    Int      @default(0) @map("retry_count")
  sentAt        DateTime @default(now()) @map("sent_at")
  deliveredAt   DateTime? @map("delivered_at")
  createdAt     DateTime @default(now()) @map("created_at")

  lead Lead? @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([advisorId])
  @@index([status])
  @@index([sentAt])
  @@map("sms_logs")
}

// ── Live Chat: Zoho Sync State ────────────────────────────────

model ZohoSyncState {
